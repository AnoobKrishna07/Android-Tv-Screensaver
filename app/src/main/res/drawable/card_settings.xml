<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">

        <shape>

            <solid android:color="#171F38"/>

            <stroke
                android:width="3dp"
                android:color="#4C8DFF"/>

            <corners android:radius="18dp"/>

        </shape>

    </item>

    <item>

        <shape>

            <solid android:color="#171F38"/>

            <stroke
                android:width="1dp"
                android:color="#283B63"/>

            <corners android:radius="18dp"/>

        </shape>

    </item>

</selector>