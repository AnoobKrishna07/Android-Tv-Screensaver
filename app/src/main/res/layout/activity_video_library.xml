<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_library">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Left -->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Library"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="28sp"/>

            <TextView
                android:id="@+id/txtVideoCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Videos • 0 Selected"
                android:textColor="#B5C7E7"
                android:textSize="15sp"/>

        </LinearLayout>

        <!-- Refresh -->

        <Button
            android:id="@+id/btnRefresh"

            android:layout_width="140dp"
            android:layout_height="44dp"

            android:layout_marginEnd="12dp"

            android:text="⟳ Refresh"

            android:textAllCaps="false"

            android:textStyle="bold"

            android:background="@drawable/button_preview"

            android:textColor="@android:color/white"/>

        <!-- Save Playlist -->

        <Button
            android:id="@+id/btnSavePlaylist"

            android:layout_width="180dp"
            android:layout_height="44dp"

            android:text="💾 Save Playlist"

            android:textAllCaps="false"

            android:textStyle="bold"

            android:background="@drawable/button_current"

            android:textColor="@android:color/white"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerVideos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>