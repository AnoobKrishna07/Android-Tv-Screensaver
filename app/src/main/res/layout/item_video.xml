<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/cardVideo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="5dp"
    android:focusable="false"
    android:focusableInTouchMode="false"

    app:cardBackgroundColor="#171F38"
    app:cardCornerRadius="14dp"
    app:cardElevation="12dp"
    app:strokeColor="#3949AB"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- LEFT ACCENT -->

        <View
            android:id="@+id/viewAccent"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#3D5AFE"/>

        <!-- CONTENT -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- THUMBNAIL -->

            <androidx.cardview.widget.CardView
                android:layout_width="180dp"
                android:layout_height="100dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp">

                <ImageView
                    android:id="@+id/imgThumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#202020"
                    android:scaleType="centerCrop"/>

            </androidx.cardview.widget.CardView>

            <!-- RIGHT SIDE -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <!-- TITLE -->

                <TextView
                    android:id="@+id/txtVideoName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Video Name"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="18sp"
                    android:maxLines="2"
                    android:ellipsize="end"/>

                <!-- INFO -->

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_video_file"/>

                    <TextView
                        android:id="@+id/txtFormat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="MP4"
                        android:textColor="#C7D2E9"
                        android:textSize="12sp"/>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="14dp"
                        android:src="@drawable/ic_resolution"/>

                    <TextView
                        android:id="@+id/txtResolution"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="1920×1080"
                        android:textColor="#C7D2E9"
                        android:textSize="12sp"/>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="14dp"
                        android:src="@drawable/ic_storage"/>

                    <TextView
                        android:id="@+id/txtSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="2.4 MB"
                        android:textColor="#C7D2E9"
                        android:textSize="12sp"/>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="14dp"
                        android:src="@drawable/ic_duration"/>

                    <TextView
                        android:id="@+id/txtDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="00:15"
                        android:textColor="#C7D2E9"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- BUTTON ROW -->

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPreview"
                        android:layout_width="125dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="10dp"
                        android:text="▶ Preview"
                        android:textColor="@android:color/white"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        app:backgroundTint="#283593"
                        app:cornerRadius="12dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetScreenSaver"
                        android:layout_width="170dp"
                        android:layout_height="42dp"
                        android:text="☆ Set Screen Saver"
                        android:textColor="@android:color/white"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        app:backgroundTint="#1565C0"
                        app:cornerRadius="12dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>